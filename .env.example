# ─── Copy to .env and fill in values ─────────────────────────────────────────
# cp .env.example .env

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: groq | openai | gemini | ollama
# Leave blank to auto-detect from whichever key is set below.
LLM_PROVIDER=groq

# ─── Groq — FREE (RECOMMENDED) ───────────────────────────────────────────────
# Sign up free at: https://console.groq.com
# Models: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (if you have credits) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Google Gemini — FREE tier ────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# Models: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ─── Ollama — 100% Local (no API key needed) ──────────────────────────────────
# Install: https://ollama.com  then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ─── Shared LLM Settings ──────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
MAX_TOKENS=1024

# ─── Embedding Settings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Chunking Defaults ────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_TOKENS=30

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5
COLLECTION_NAME=docchat

# ─── Triage ───────────────────────────────────────────────────────────────────
MIN_DOC_TOKENS=20
